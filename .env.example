# MapTiler — map tiles/style. Get a key at https://cloud.maptiler.com/account/keys/
VITE_MAPTILER_API_KEY=your-maptiler-key-here

# OpenRouteService — driving directions. Get a key at https://openrouteservice.org/dev/#/signup
VITE_OPENROUTESERVICE_API_KEY=your-openrouteservice-key-here
# Copy this file to .env and fill in your key.
# Google Gemini API key used by src/lib/timetable.ts for timetable analysis.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
